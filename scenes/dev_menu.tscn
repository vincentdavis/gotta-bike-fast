[gd_scene format=3 load_steps=2]

[ext_resource type="Script" path="res://scripts/ui/dev_menu.gd" id="1_dev"]

[node name="DevMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_dev")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.10, 0.14, 1)

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
theme_override_constants/margin_left = 80
theme_override_constants/margin_right = 80
theme_override_constants/margin_top = 40
theme_override_constants/margin_bottom = 40

[node name="VBox" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Dev Settings"
theme_override_font_sizes/font_size = 36

[node name="Subtitle" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Service URLs the client talks to. Persisted to user://dev_settings.cfg."
theme_override_font_sizes/font_size = 14
modulate = Color(0.75, 0.75, 0.75, 1)

[node name="EnvRow" type="HBoxContainer" parent="Margin/VBox"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="EnvLabel" type="Label" parent="Margin/VBox/EnvRow"]
layout_mode = 2
size_flags_vertical = 4
text = "Environment"
theme_override_font_sizes/font_size = 18

[node name="EnvOption" type="OptionButton" parent="Margin/VBox/EnvRow"]
layout_mode = 2
custom_minimum_size = Vector2(220, 0)
theme_override_font_sizes/font_size = 18

[node name="BackendLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Backend (FastAPI)"
theme_override_font_sizes/font_size = 16

[node name="BackendInput" type="LineEdit" parent="Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(480, 0)
placeholder_text = "http://127.0.0.1:8001"
theme_override_font_sizes/font_size = 18

[node name="WebLabel" type="Label" parent="Margin/VBox"]
layout_mode = 2
text = "Web (Django)"
theme_override_font_sizes/font_size = 16

[node name="WebInput" type="LineEdit" parent="Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(480, 0)
