[gd_scene format=3 load_steps=2]

[ext_resource type="Script" path="res://scripts/ui/login.gd" id="1_login"]

[node name="Login" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
script = ExtResource("1_login")

[node name="Background" type="ColorRect" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
color = Color(0.08, 0.10, 0.14, 1)

[node name="Center" type="CenterContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="Panel" type="PanelContainer" parent="Center"]
layout_mode = 2

[node name="Margin" type="MarginContainer" parent="Center/Panel"]
layout_mode = 2
theme_override_constants/margin_left = 32
theme_override_constants/margin_right = 32
theme_override_constants/margin_top = 26
theme_override_constants/margin_bottom = 26

[node name="VBox" type="VBoxContainer" parent="Center/Panel/Margin"]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Title" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "GOTTA BIKE FAST"
theme_override_font_sizes/font_size = 32
horizontal_alignment = 1

[node name="Subtitle" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "Sign in"
theme_override_font_sizes/font_size = 22
horizontal_alignment = 1

[node name="EmailLabel" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "Email"
theme_override_font_sizes/font_size = 16

[node name="EmailInput" type="LineEdit" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(360, 0)
placeholder_text = "you@example.com"
theme_override_font_sizes/font_size = 20

[node name="PasswordLabel" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "Password"
theme_override_font_sizes/font_size = 16

[node name="PasswordInput" type="LineEdit" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
secret = true
placeholder_text = "your password"
theme_override_font_sizes/font_size = 20

[node name="StatusLabel" type="Label" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = ""
theme_override_font_sizes/font_size = 16
horizontal_alignment = 1

[node name="SubmitButton" type="Button" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(360, 0)
text = "Sign in"
theme_override_font_sizes/font_size = 22

[node name="Divider" type="HSeparator" parent="Center/Panel/Margin/VBox"]
layout_mode = 2

[node name="SignupLink" type="Button" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "Create account (opens browser)"
theme_override_font_sizes/font_size = 16
flat = true

[node name="ResetLink" type="Button" parent="Center/Panel/Margin/VBox"]
layout_mode = 2
text = "Forgot password (opens browser)"
theme_override_font_sizes/font_size = 16
flat = true
